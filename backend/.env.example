# ─────────────────────────────────────────────
# HumanOS Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── NVIDIA API ────────────────────────────────
# Get your API key from: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The chat model to use (NVIDIA NIM endpoint)
NVIDIA_CHAT_MODEL=meta/llama-3.1-70b-instruct

# NVIDIA API base URL
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Supabase ──────────────────────────────────────────────────────────────────
# OPTIONAL in Phase 1 — not used yet. Required in Phase 2 (auth + memory).
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ───────────────────────────────────────
APP_VERSION=1.0.0

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins
# For development: http://localhost:3001,http://localhost:8081
# For production: your actual app URL
CORS_ORIGINS=http://localhost:3001,http://localhost:8081
